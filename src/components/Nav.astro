---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Work' },
  { href: '/research', label: 'Research' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '';
  return currentPath.startsWith(href);
}
---

<header class="pt-0 pb-8 md:pb-12">
  {/* WebGPU Logo Header */}
  <a href="/" class="block" aria-label="See Through Lab">
    <div id="webgpu-header" class="relative w-full h-[280px] md:h-[400px] lg:h-[450px]">
      <canvas id="canvas" class="block w-full h-full" style="touch-action: none;"></canvas>
      <div id="loading" class="absolute inset-0 flex items-center justify-center text-text-muted text-sm z-10 transition-opacity duration-500" style="opacity: 1;">
        Loading...
      </div>
      <div id="error" class="hidden absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-red-900/10 border border-red-500/50 text-red-400 p-5 rounded-lg max-w-[80%] text-center z-10"></div>
    </div>
  </a>

  {/* Desktop nav */}
  <nav class="hidden md:flex justify-center gap-8" aria-label="Main navigation">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'text-nav uppercase tracking-widest py-2 transition-colors duration-200',
          isActive(link.href) ? 'text-text-primary' : 'text-text-muted hover:text-text-primary',
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>

  {/* Mobile nav */}
  <details class="md:hidden text-center">
    <summary
      class="text-nav uppercase tracking-widest text-text-muted cursor-pointer list-none py-3 min-h-[44px] flex items-center justify-center"
      aria-label="Toggle navigation menu"
    >
      Menu
    </summary>
    <nav class="flex flex-col gap-1 pb-4" aria-label="Main navigation">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-nav uppercase tracking-widest py-3 min-h-[44px] flex items-center justify-center transition-colors duration-200',
            isActive(link.href) ? 'text-text-primary' : 'text-text-muted hover:text-text-primary',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </details>
</header>

<script is:inline type="module" src="/home/js/main.js"></script>
