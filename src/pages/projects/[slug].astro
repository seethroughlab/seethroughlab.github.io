---
import { readdir } from 'node:fs/promises';
import { join } from 'node:path';
import Base from '../../layouts/Base.astro';
import VideoPlayer from '../../components/VideoPlayer.astro';
import ImageCarousel from '../../components/ImageCarousel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const IMAGE_RE = /\.(jpe?g|png|gif|webp|avif)$/i;
  const projects = await getCollection('projects');
  const paths = await Promise.all(
    projects.map(async (project) => {
      const slug = project.data.slug;
      const dir = join(process.cwd(), 'public', 'images', 'projects', slug);
      let images: string[] = [];
      try {
        const files = await readdir(dir);
        images = files
          .filter((f) => IMAGE_RE.test(f))
          .sort()
          .map((f) => `/images/projects/${slug}/${f}`);
      } catch {
        // No image directory for this project
      }
      return {
        params: { slug },
        props: { project, images },
      };
    })
  );
  return paths;
}

const { project, images } = Astro.props;
const { title, client, year, coverImage, videoSrc, role, tech } = project.data;
const { Content } = await render(project);

const hasVideo = !!videoSrc;
const hasCarousel = images.length > 0;
---

<Base title={`${title} — See Through Lab`}>
  <article class="py-12">
    {/* Hero: video > carousel > cover image */}
    {hasVideo ? (
      <div class="max-w-5xl mx-auto mb-12">
        <VideoPlayer src={videoSrc} poster={coverImage || undefined} />
      </div>
    ) : hasCarousel ? (
      <ImageCarousel images={images} title={title} />
    ) : coverImage ? (
      <div class="max-w-5xl mx-auto aspect-video overflow-hidden mb-12">
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    ) : null}

    {/* Video projects with images: show carousel below video */}
    {hasVideo && hasCarousel && (
      <ImageCarousel images={images} title={title} />
    )}

    {/* Metadata header */}
    <div class="max-w-3xl mx-auto">
      <h1 class="font-serif text-4xl md:text-5xl mb-4">{title}</h1>

      {(client || year) && (
        <p class="text-text-muted uppercase tracking-widest text-sm mb-2">
          {[client, year].filter(Boolean).join(' · ')}
        </p>
      )}

      {role && (
        <p class="text-text-muted text-sm mb-4">{role}</p>
      )}

      {tech.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-12">
          {tech.map((t) => (
            <span class="text-xs uppercase tracking-wider text-text-muted border border-border px-3 py-1 rounded-full">
              {t}
            </span>
          ))}
        </div>
      )}

      {/* If no tech but we still need spacing before body */}
      {tech.length === 0 && <div class="mb-12" />}

      {/* MDX body */}
      <div class={`prose${hasCarousel ? ' prose-no-images' : ''}`}>
        <Content />
      </div>

      {/* Back navigation */}
      <a
        href="/"
        class="inline-block mt-16 text-text-muted hover:text-text-primary transition-colors duration-200 text-sm uppercase tracking-widest"
      >
        &larr; Back to Work
      </a>
    </div>
  </article>
</Base>
