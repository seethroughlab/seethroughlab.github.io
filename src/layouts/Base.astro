---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'See Through Lab',
  description = 'Experimental art & technology studio.',
  ogImage,
} = Astro.props;

const siteUrl = 'https://seethroughlab.com';
const ogImageUrl = ogImage
  ? ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? "summary_large_image" : "summary"} />
  </head>
  <body class="bg-bg text-text-primary font-sans min-h-screen flex flex-col">
    <canvas id="bg-canvas" class="fixed inset-0 w-screen h-screen pointer-events-none" style="z-index: 0;"></canvas>
    <div class="relative max-w-[var(--container-content)] mx-auto px-6 md:px-12 w-full flex flex-col min-h-screen" style="z-index: 10;">
      <Nav />
      <main class="flex-1">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
