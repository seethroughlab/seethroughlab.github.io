---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8 mt-16">
  <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-text-muted text-sm">
    <p>&copy; {year} See Through Lab</p>
    <div class="flex gap-6">
      <a
        href="https://instagram.com/seethroughlab"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-text-primary transition-colors duration-200 min-h-[44px] min-w-[44px] flex items-center justify-center"
      >
        Instagram
      </a>
      <a
        href="https://github.com/seethroughlab"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-text-primary transition-colors duration-200 min-h-[44px] min-w-[44px] flex items-center justify-center"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
