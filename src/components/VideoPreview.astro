---
interface Props {
  src: string;
  poster: string;
  alt: string;
  startTime?: number;
}

const { src, poster, alt, startTime } = Astro.props;
---

<div class="video-preview relative w-full h-full" data-hls-src={src} data-start-time={startTime || undefined}>
  <img
    src={poster}
    alt={alt}
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
  />
  <video
    class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-700"
    muted
    loop
    playsinline
    preload="none"
  />
</div>

<script>
  const HLS_CDN = "https://cdn.jsdelivr.net/npm/hls.js@1/dist/hls.min.js";
  let hlsPromise: Promise<typeof globalThis.Hls | null> | null = null;
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function loadHlsLib(): Promise<typeof globalThis.Hls | null> {
    if (!hlsPromise) {
      hlsPromise = new Promise((resolve) => {
        const testVideo = document.createElement("video");
        if (testVideo.canPlayType("application/vnd.apple.mpegurl")) {
          resolve(null); // Safari — native HLS
        } else if ((window as any).Hls) {
          resolve((window as any).Hls);
        } else {
          const script = document.createElement("script");
          script.src = HLS_CDN;
          script.onload = () => resolve((window as any).Hls);
          script.onerror = () => resolve(null);
          document.head.appendChild(script);
        }
      });
    }
    return hlsPromise;
  }

  function isNativeHLS(): boolean {
    const v = document.createElement("video");
    return !!v.canPlayType("application/vnd.apple.mpegurl");
  }

  const previews = document.querySelectorAll<HTMLElement>(".video-preview");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        const container = entry.target as HTMLElement;
        const video = container.querySelector("video")!;
        const src = container.dataset.hlsSrc!;

        if (entry.isIntersecting) {
          startPlayback(container, video, src);
        } else {
          stopPlayback(container, video);
        }
      });
    },
    { threshold: 0.25 },
  );

  async function startPlayback(
    container: HTMLElement,
    video: HTMLVideoElement,
    src: string,
  ) {
    if (container.dataset.active === "true") return;
    container.dataset.active = "true";

    const startTime = parseFloat(container.dataset.startTime || "0");

    if (isNativeHLS()) {
      video.src = src;
      if (startTime) video.currentTime = startTime;
      video.addEventListener("playing", () => fadeIn(video), { once: true });
      try { await video.play(); } catch { /* autoplay blocked */ }
    } else {
      const HlsLib = await loadHlsLib();
      if (HlsLib && HlsLib.isSupported()) {
        const hls = new HlsLib({ capLevelToPlayerSize: true, startPosition: startTime || -1 });
        (container as any)._hls = hls;
        hls.loadSource(src);
        hls.attachMedia(video);
        video.addEventListener("playing", () => fadeIn(video), { once: true });
        hls.on(HlsLib.Events.MANIFEST_PARSED, async () => {
          try { await video.play(); } catch { /* autoplay blocked */ }
        });
      }
    }
  }

  function stopPlayback(container: HTMLElement, video: HTMLVideoElement) {
    if (container.dataset.active !== "true") return;
    container.dataset.active = "false";
    video.pause();
    video.style.opacity = "0";
    video.removeAttribute("src");
    video.load(); // release buffer

    const hls = (container as any)._hls;
    if (hls) {
      hls.destroy();
      (container as any)._hls = null;
    }
  }

  function fadeIn(video: HTMLVideoElement) {
    video.style.opacity = "1";
  }

  if (!prefersReducedMotion) {
    previews.forEach((el) => observer.observe(el));
  }
</script>
