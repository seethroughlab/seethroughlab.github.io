---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Work' },
  { href: '/research', label: 'Research' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/' || currentPath === '';
  return currentPath.startsWith(href);
}
---

<header class="pt-12 pb-8 md:pt-16 md:pb-12">
  {/* Logo */}
  <a href="/" class="block mb-4">
    <h1 class="logo-text select-none" aria-label="See Through Lab">
      SEE<br />THROUGH<br />LAB
    </h1>
  </a>

  {/* Tagline */}
  <p class="text-center text-tagline text-text-muted mb-8">
    Experimental art & technology studio.
  </p>

  {/* Desktop nav */}
  <nav class="hidden md:flex justify-center gap-8" aria-label="Main navigation">
    {links.map((link) => (
      <a
        href={link.href}
        class:list={[
          'text-nav uppercase tracking-widest py-2 transition-colors duration-200',
          isActive(link.href) ? 'text-text-primary' : 'text-text-muted hover:text-text-primary',
        ]}
      >
        {link.label}
      </a>
    ))}
  </nav>

  {/* Mobile nav */}
  <details class="md:hidden text-center">
    <summary
      class="text-nav uppercase tracking-widest text-text-muted cursor-pointer list-none py-3 min-h-[44px] flex items-center justify-center"
      aria-label="Toggle navigation menu"
    >
      Menu
    </summary>
    <nav class="flex flex-col gap-1 pb-4" aria-label="Main navigation">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            'text-nav uppercase tracking-widest py-3 min-h-[44px] flex items-center justify-center transition-colors duration-200',
            isActive(link.href) ? 'text-text-primary' : 'text-text-muted hover:text-text-primary',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </details>
</header>
