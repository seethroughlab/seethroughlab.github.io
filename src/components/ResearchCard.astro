---
interface Props {
  title: string;
  slug: string;
  subtitle: string;
  status: 'active' | 'archived' | 'experiment';
  coverImage: string;
}

const { title, slug, subtitle, status, coverImage } = Astro.props;

const statusStyles: Record<string, string> = {
  active: 'border-emerald-800 text-emerald-500',
  archived: 'border-border text-text-muted',
  experiment: 'border-amber-800 text-amber-500',
};
---

<a href={`/research/${slug}`} class="group block">
  {coverImage ? (
    <div class="aspect-video overflow-hidden bg-surface">
      <img
        src={coverImage}
        alt={title}
        class="w-full h-full object-cover transition-[filter] duration-300 group-hover:brightness-110"
        loading="lazy"
      />
    </div>
  ) : (
    <div class="aspect-video bg-surface flex items-center justify-center p-8">
      <h3 class="font-serif text-2xl md:text-3xl text-text-muted transition-colors duration-300 group-hover:text-text-primary text-center">
        {title}
      </h3>
    </div>
  )}

  <div class="pt-4">
    <div class="flex items-center gap-3 mb-2">
      {coverImage && (
        <h3 class="font-serif text-2xl md:text-3xl text-text-muted transition-colors duration-300 group-hover:text-text-primary">
          {title}
        </h3>
      )}
      <span class={`text-xs uppercase tracking-wider rounded-full border px-3 py-1 ${statusStyles[status]}`}>
        {status}
      </span>
    </div>
    {subtitle && (
      <p class="text-text-muted text-sm">{subtitle}</p>
    )}
  </div>
</a>
